# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{js,jsx,json}]
indent_size = 2
max_line_length = 100

[*.{py}]
indent_size = 4
max_line_length = 100

[*.{md}]
trim_trailing_whitespace = false
max_line_length = off

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
